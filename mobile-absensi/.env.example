EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-hosted-anon-key
# Optional for local fallback: set EXPO_PUBLIC_SUPABASE_URL=auto

# Sentry error reporting (production)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development

# Geofence (optional, fallback ke DB system_settings)
EXPO_PUBLIC_HOSPITAL_LAT=
EXPO_PUBLIC_HOSPITAL_LNG=
EXPO_PUBLIC_HOSPITAL_RADIUS_M=500
EXPO_PUBLIC_GEOFENCE_ENABLED=false
