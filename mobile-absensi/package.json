{
  "name": "hrms-absensi-mobile",
  "private": true,
  "version": "0.1.0",
  "description": "Mobile attendance app for HRMS, connected directly to local Supabase.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:dev:8082": "expo start --dev-client --port 8082",
    "start:dev:usb": "expo start --dev-client --localhost",
    "android": "expo run:android",
    "android:dev": "npm run android:install:stable && npm run start:dev:8082",
    "android:install:stable": "cd android && gradlew.bat app:installDebug -x lint -x test -PreactNativeArchitectures=arm64-v8a",
    "android:release": "expo run:android --variant release",
    "build:android:release": "cd android && gradlew.bat assembleRelease",
    "check:android:release-ready": "node scripts/check-android-release-ready.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@sentry/react-native": "^8.11.1",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~51.0.28",
    "expo-camera": "~15.0.16",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-dev-client": "~4.0.28",
    "expo-file-system": "~17.0.1",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.1.0",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "jpeg-js": "^0.4.4",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-nitro-image": "^0.14.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vision-camera": "^5.0.9",
    "react-native-vision-camera-face-detector": "^1.10.2",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
