# ───────────────────────────────────────────────
# HRMS Pro — Environment Variables (Web)
# Copy to .env.local and fill in values
# ───────────────────────────────────────────────

# ── Supabase (REQUIRED) ──
# Set ke 'auto' untuk pakai Supabase di hostname yang sama (port 54321),
# atau gunakan URL hosted Supabase: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional: Split Auth & Data Supabase Projects ──
# Hanya perlu kalau menggunakan dua project Supabase terpisah
# VITE_AUTH_SUPABASE_URL=
# VITE_AUTH_SUPABASE_ANON_KEY=
# VITE_DATA_SUPABASE_URL=
# VITE_DATA_SUPABASE_ANON_KEY=

# ── Gemini AI (untuk fitur AI Assistant) ──
GEMINI_API_KEY=

# ── OAuth Redirect URLs ──
# Default: window.location.origin
# VITE_OAUTH_REDIRECT_URL=https://hrms.your-domain.com
# VITE_PASSWORD_RESET_REDIRECT_URL=https://hrms.your-domain.com/reset-password

# ── Geofencing Absensi ──
# Koordinat kantor dan radius toleransi (meter)
VITE_ATTENDANCE_CENTER_LAT=-6.200000
VITE_ATTENDANCE_CENTER_LNG=106.816666
VITE_ATTENDANCE_RADIUS_METERS=300

# ── Hikvision Device (Optional) ──
# Untuk integrasi mesin absensi Hikvision
# VITE_HIKVISION_DEVICE_IP=192.168.1.100
# VITE_HIKVISION_DEVICE_PORT=80
# VITE_HIKVISION_USERNAME=admin
# VITE_HIKVISION_PASSWORD=
# VITE_HIKVISION_DEVICE_LOCATION=Kantor Utama
# VITE_HIKVISION_SYNC_INTERVAL_MINUTES=5
# VITE_HIKVISION_SYNC_ENABLED=false
